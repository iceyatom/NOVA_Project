# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
*.test.*
*.spec.*
!src/**/*.test.ts
!src/**/*.test.tsx
!src/**/*.spec.ts
!src/**/*.spec.tsx

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#lighthouse reports
/docs/lighthouse/
/docs/image-upload-ui.md
/docs/amazon-storage.md

# Prisma Client
/src/generated/prisma

# Prisma Migrations
prisma/migrations/
/src/generated/prisma

# Ignore all hidden files/folders (dot-prefixed)
.*
!.gitignore

