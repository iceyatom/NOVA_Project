generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model CatalogItem {
  id                Int       @id @default(autoincrement())
  sku               String?
  itemName          String
  price             Decimal   @default(0.00) @db.Decimal(10, 2)
  category3         Int?
  category2         Int?
  category1         Int?
  description       String?   @db.Text
  quantityInStock   Int       @default(0)
  unitOfMeasure     String?
  storageLocation   String?
  storageConditions String?
  expirationDate    DateTime?
  dateAcquired      DateTime?
  reorderLevel      Int       @default(0)
  unitCost          Decimal   @default(0.00) @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category3Ref Category3? @relation("CatalogItemCategory3", fields: [category3], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category2Ref Category2? @relation("CatalogItemCategory2", fields: [category2], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category1Ref Category1? @relation("CatalogItemCategory1", fields: [category1], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([category1])
  @@index([category2])
  @@index([category3])
  @@index([price])
  @@index([updatedAt])
  @@index([quantityInStock])
}

model Category3 {
  id   Int    @id @default(autoincrement())
  name String @unique

  category2Items  Category2[]
  catalogItems    CatalogItem[] @relation("CatalogItemCategory3")
}

model Category2 {
  id          Int    @id @default(autoincrement())
  name        String
  category3Id Int

  category3   Category3 @relation(fields: [category3Id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category1Items Category1[]
  catalogItems   CatalogItem[] @relation("CatalogItemCategory2")

  @@unique([category3Id, name])
  @@index([category3Id])
}

model Category1 {
  id          Int    @id @default(autoincrement())
  name        String
  category2Id Int

  category2    Category2 @relation(fields: [category2Id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  catalogItems CatalogItem[] @relation("CatalogItemCategory1")

  @@unique([category2Id, name])
  @@index([category2Id])
}

model Account {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  passwordHash        String
  status              String    @default("active")
  role                String
  displayName         String?
  phone               String?
  notes               String?
  lastLoginAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  sensitiveUpdatedAt  DateTime?
}

model Ticket {
  id                 Int      @id @default(autoincrement())
  createdByAccountId Int
  type               String
  note               String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdByAccountId])
  @@index([createdAt])
}

model TicketLine {
  id            Int @id @default(autoincrement())
  ticketId      Int
  catalogItemId Int
  countDelta    Int

  @@index([ticketId])
  @@index([catalogItemId])
}

model Task {
  id                  Int       @id @default(autoincrement())
  title               String
  description         String?   @db.Text
  assignedToAccountId Int
  createdAt           DateTime  @default(now())
  isCompleted         Boolean   @default(false)
  completedAt         DateTime?
  expiresAt           DateTime

  @@index([assignedToAccountId])
  @@index([isCompleted])
  @@index([expiresAt])
}