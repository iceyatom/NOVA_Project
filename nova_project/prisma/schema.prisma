generator client {
  provider = "prisma-client-js"
  // output not needed; default is fine
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  // keep this only if you will run prisma migrate
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model CatalogItem {
  id                Int       @id @default(autoincrement())
  sku               String?
  itemName          String
  price             Decimal   @default(0) @db.Decimal(10, 2)
  category3         Int?
  category2         Int?
  category1         Int?
  description       String?   @db.Text
  quantityInStock   Int       @default(0)
  unitOfMeasure     String?
  storageLocation   String?
  storageConditions String?
  expirationDate    DateTime?
  dateAcquired      DateTime?
  reorderLevel      Int       @default(0)
  unitCost          Decimal   @default(0) @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category3Ref Category3? @relation("CatalogItemCategory3", fields: [category3], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category2Ref Category2? @relation("CatalogItemCategory2", fields: [category2], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category1Ref Category1? @relation("CatalogItemCategory1", fields: [category1], references: [id], onDelete: SetNull, onUpdate: Cascade)
  ticketLines  TicketLine[]
  images       CatalogItemImage[]

  @@index([category1])
  @@index([category2])
  @@index([category3])
  @@index([price])
  @@index([updatedAt])
  @@index([quantityInStock])
}

model CatalogItemImage {
  id            Int         @id @default(autoincrement())
  catalogItemId Int
  s3Key         String
  createdAt     DateTime    @default(now())

  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([catalogItemId])
  @@index([s3Key])
}

model Category3 {
  id   Int    @id @default(autoincrement())
  name String @unique

  category2s   Category2[]
  catalogItems CatalogItem[] @relation("CatalogItemCategory3")
}

model Category2 {
  id          Int    @id @default(autoincrement())
  name        String
  category3Id Int

  category3    Category3     @relation(fields: [category3Id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category1s   Category1[]
  catalogItems CatalogItem[] @relation("CatalogItemCategory2")

  @@unique([category3Id, name])
  @@index([category3Id])
}

model Category1 {
  id          Int    @id @default(autoincrement())
  name        String
  category2Id Int

  category2    Category2     @relation(fields: [category2Id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  catalogItems CatalogItem[] @relation("CatalogItemCategory1")

  @@unique([category2Id, name])
  @@index([category2Id])
}

model Account {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String
  status       String  @default("active")
  role         String
  displayName  String?
  phone        String?
  notes        String?

  lastLoginAt DateTime?
  deletedAt   DateTime?

  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks               Task[]               @relation("AccountTasks")
  pendingVerification PendingVerification?
  sessions            Session[]
}

model PendingVerification {
  id        Int      @id @default(autoincrement())
  accountId Int      @unique
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Ticket {
  id                Int      @id @default(autoincrement())
  createdByAccountId Int
  type              String
  note              String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ticketLines      TicketLine[]

  @@index([createdByAccountId])
  @@index([createdAt])
}

model TicketLine {
  id            Int @id @default(autoincrement())
  ticketId      Int
  catalogItemId Int
  countDelta    Int

  ticket      Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([ticketId])
  @@index([catalogItemId])
}

model Task {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?  @db.Text
  status              TaskStatus @default(NOT_STARTED)
  assignedToAccountId Int
  createdAt           DateTime @default(now())
  completedAt         DateTime?
  expiresAt           DateTime

  assignedTo Account @relation("AccountTasks", fields: [assignedToAccountId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([assignedToAccountId])
  @@index([expiresAt])
}

enum TaskStatus {
  NOT_STARTED @map("Not Started")
  IN_PROGRESS @map("In Progress")
  COMPLETE    @map("Complete")
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  accountId Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}
